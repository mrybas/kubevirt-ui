# =============================================================================
# KubeVirt UI — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables have sensible defaults for local development.

# ── Backend ──────────────────────────────────────────────────────────────────

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# CORS allowed origins (comma-separated). Empty = no CORS.
# For dev: http://localhost:3333,http://192.168.196.1:3333
CORS_ORIGINS=

# ── Kubernetes ───────────────────────────────────────────────────────────────

# Path to kubeconfig file. In Docker, mount the file and set this path.
# When running in-cluster (K8S_IN_CLUSTER=true), this is ignored.
KUBECONFIG=/app/kubeconfig

# Set to true when running inside a Kubernetes pod (uses ServiceAccount token).
K8S_IN_CLUSTER=false

# ── Authentication ───────────────────────────────────────────────────────────

# Auth mode: none (no auth), oidc (OpenID Connect), token (K8s bearer token)
AUTH_TYPE=none

# OIDC issuer URL — must be reachable from the browser for token validation.
# Example: https://dex.example.com or http://localhost:5556
OIDC_ISSUER=

# Internal OIDC issuer URL — used by the backend to communicate with the IdP.
# Falls back to OIDC_ISSUER if not set.
# Useful when the public issuer URL is not reachable from the backend container.
OIDC_INTERNAL_URL=

# OIDC client ID registered with the identity provider.
OIDC_CLIENT_ID=kubevirt-ui

# OIDC client secret (if the IdP requires a confidential client).
OIDC_CLIENT_SECRET=

# ── LLDAP (bundled user management) ─────────────────────────────────────────

# Enable bundled LLDAP integration for user/group management via the UI.
LLDAP_ENABLED=false

# LLDAP web API URL (GraphQL + auth endpoints).
LLDAP_URL=http://lldap:17170

# LLDAP admin credentials.
LLDAP_ADMIN_USER=admin
LLDAP_ADMIN_PASSWORD=admin_password

# LDAP base DN — must match the LLDAP server configuration.
LLDAP_LDAP_BASE_DN=dc=kubevirt,dc=local

# LLDAP LDAP protocol host and port (used for LDAP bind operations).
LLDAP_LDAP_HOST=lldap
LLDAP_LDAP_PORT=3890

# ── Metrics ──────────────────────────────────────────────────────────────────

# Force metrics fetch mode: true = direct HTTP, false = K8s API proxy.
# Empty = auto-detect (direct when in-cluster).
METRICS_DIRECT=

# Override metrics backend service (format: namespace/service:port).
# Empty = auto-discovery via VMSingle CRD or service labels.
# Example: victoria-metrics/vmsingle-vmsingle:8429
METRICS_SERVICE=

# ── Kubernetes OIDC (optional — for kubeconfig generation) ──────────────────

# Set to true if the K8s API server is configured with --oidc-issuer-url.
# Enables OIDC-based kubeconfig variants in the /auth/kubeconfig endpoint.
K8S_OIDC_ENABLED=false

# ── Feature Flags ────────────────────────────────────────────────────────────

# Enable multi-tenant mode (project isolation via namespaces).
ENABLE_TENANTS=false

# ── Frontend (Vite build-time variables) ─────────────────────────────────────

# Backend API URL — used by the frontend dev server.
# In production (nginx), the frontend proxies /api to the backend automatically.
VITE_API_URL=http://localhost:8888

# OIDC issuer URL — used by the frontend for login redirects.
# Must match AUTH_TYPE=oidc on the backend.
VITE_DEX_ISSUER=

# OIDC client ID — must match OIDC_CLIENT_ID on the backend.
VITE_OIDC_CLIENT_ID=kubevirt-ui
